generator client {
  provider        = "prisma-client-js"
  // Habilitamos esta preview feature para luego poder inyectar el tenant_id
  previewFeatures = ["clientExtensions"] 
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// CORE: Gestión de Negocios y Usuarios
// ------------------------------------------------------

model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  industry  String   // Ej: "cellphone_repair", "psychology_clinic"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  customers    Customer[]
  appointments Appointment[]
  repairOrders RepairOrder[]
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  email     String   @unique
  password  String
  role      String   @default("EMPLOYEE") // Roles: ADMIN, EMPLOYEE
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId]) // Índice crítico para la velocidad de las consultas
}

// ------------------------------------------------------
// CRM: Clientes compartidos entre módulos del mismo negocio
// ------------------------------------------------------

model Customer {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  phone     String   // Clave para la automatización por WhatsApp
  name      String?
  createdAt DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  repairOrders RepairOrder[]

  @@unique([tenantId, phone]) // Un número de teléfono es único por negocio
  @@index([tenantId])
}

// ------------------------------------------------------
// MÓDULO A: Agenda y Turnos
// ------------------------------------------------------

model Appointment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  customerId  String   @db.Uuid
  serviceName String
  startTime   DateTime
  endTime     DateTime
  status      String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  createdAt   DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ------------------------------------------------------
// MÓDULO B: Servicio Técnico / Reparaciones
// ------------------------------------------------------

model RepairOrder {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  customerId  String   @db.Uuid
  deviceModel String   // Ej: "iPhone 13 Pro", "Samsung S23"
  issue       String
  status      String   @default("RECEIVED") // RECEIVED, IN_PROGRESS, REPAIRED, DELIVERED
  cost        Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}